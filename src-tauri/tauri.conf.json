{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vael",
  "version": "0.6.0",
  "identifier": "com.vael.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Vael",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": false
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "width": 220,
        "height": 56,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Vasya1996/vael-desktop/releases/latest/download/latest.json",
        "https://vaelcopilot.tractioneye.xyz/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM1MEFGNTdBQjNFRDYwMUIKUldRYllPMnpldlVLTlJ1NWY0dTFqNFhST2JvWHpTb2xzcDVoc04zN0Z4Mk9XVE95elVhWE9GUmMK",
      "windows": {
        "installMode": "quiet"
      }
    }
  }
}
